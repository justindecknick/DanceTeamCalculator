  <script>
    // Constants
    const COMPANY_PRICE = 800;
    const FORCE_PRICE = 600;
    const MONTHS = 9;
    const MAX_DANCES = 10;

    // DOM Elements
    const companyInput = document.getElementById('company-dances');
    const forceInput = document.getElementById('force-dances');
    
    const companySubtotalEl = document.getElementById('company-subtotal');
    const forceSubtotalEl = document.getElementById('force-subtotal');
    const annualTotalEl = document.getElementById('annual-total');
    const monthlyInstallmentEl = document.getElementById('monthly-installment');

    const groupCompany = document.getElementById('group-company');
    const groupForce = document.getElementById('group-force');
    const errorCompany = document.getElementById('error-company');
    const errorForce = document.getElementById('error-force');

    // Format utility for currency
    function formatCurrency(amount) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD'
      }).format(amount);
    }

    // Main calculation & UI updates
    function calculateTuition() {
      let companyVal = parseInt(companyInput.value) || 0;
      let forceVal = parseInt(forceInput.value) || 0;

      // Ensure inputs are constrained
      companyVal = Math.max(0, Math.min(MAX_DANCES, companyVal));
      forceVal = Math.max(0, Math.min(MAX_DANCES, forceVal));

      // Calculate subtotals and totals
      const companySubtotal = companyVal * COMPANY_PRICE;
      const forceSubtotal = forceVal * FORCE_PRICE;
      const annualTotal = companySubtotal + forceSubtotal;
      const monthlyInstallment = annualTotal / MONTHS;

      // Update Subtotal Displays
      companySubtotalEl.textContent = formatCurrency(companySubtotal);
      forceSubtotalEl.textContent = formatCurrency(forceSubtotal);

      // Update Final Values
      annualTotalEl.textContent = formatCurrency(annualTotal);
      
      // Update monthly display with the appropriate HTML layout
      monthlyInstallmentEl.innerHTML = `${formatCurrency(monthlyInstallment)}<span>/mo</span>`;

      // Update button disabled states based on current values
      updateButtonStates('company-dances', companyVal);
      updateButtonStates('force-dances', forceVal);
    }

    // Handles button clicks (+ / -)
    function adjustCount(inputId, amount) {
      const input = document.getElementById(inputId);
      let currentValue = parseInt(input.value) || 0;
      let newValue = currentValue + amount;

      // Trigger error animations and clamp if limits exceeded
      if (newValue > MAX_DANCES) {
        showValidationError(inputId);
        newValue = MAX_DANCES;
      } else if (newValue < 0) {
        newValue = 0;
      } else {
        clearValidationError(inputId);
      }

      input.value = newValue;
      calculateTuition();
    }

    // Input event validation & enforcement (runs when users type)
    function handleInputValidation(inputEl) {
      let value = inputEl.value;
      const inputId = inputEl.id;

      // Check if it's blank first (to allow typing/backspacing)
      if (value === "") {
        return;
      }

      let numericVal = parseInt(value);

      if (isNaN(numericVal)) {
        inputEl.value = 0;
        clearValidationError(inputId);
      } else if (numericVal > MAX_DANCES) {
        showValidationError(inputId);
        inputEl.value = MAX_DANCES;
      } else if (numericVal < 0) {
        showValidationError(inputId);
        inputEl.value = 0;
      } else {
        clearValidationError(inputId);
      }
      
      calculateTuition();
    }

    // Empty validation clean up on blur (e.g. if field is left empty, set to 0)
    function handleBlurCleanUp(inputEl) {
      if (inputEl.value === "") {
        inputEl.value = 0;
        calculateTuition();
      }
    }

    // Trigger visual shake and styling on validation boundary breach
    function showValidationError(inputId) {
      const isCompany = inputId.includes('company');
      const groupEl = isCompany ? groupCompany : groupForce;
      const errorEl = isCompany ? errorCompany : errorForce;

      groupEl.classList.add('has-error');
      errorEl.style.display = 'block';

      // Remove shake class after animation completes so it can trigger again
      groupEl.addEventListener('animationend', () => {
        groupEl.classList.remove('shake');
      }, { once: true });

      // Add shake class immediately to start animation
      groupEl.classList.add('shake');
    }

    // Clear validation error highlights
    function clearValidationError(inputId) {
      const isCompany = inputId.includes('company');
      const groupEl = isCompany ? groupCompany : groupForce;
      const errorEl = isCompany ? errorCompany : errorForce;

      groupEl.classList.remove('has-error');
      errorEl.style.display = 'none';
    }

    // Sync button disabling based on range boundary
    function updateButtonStates(inputId, currentValue) {
      const group = inputId.includes('company') ? 'company' : 'force';
      const decBtn = document.querySelector(`#group-${group} .decrement`);
      const incBtn = document.querySelector(`#group-${group} .increment`);

      if (decBtn && incBtn) {
        decBtn.disabled = currentValue <= 0;
        incBtn.disabled = currentValue >= MAX_DANCES;
      }
    }

    // Bind event listeners
    [companyInput, forceInput].forEach(inputEl => {
      inputEl.addEventListener('input', () => handleInputValidation(inputEl));
      inputEl.addEventListener('blur', () => handleBlurCleanUp(inputEl));
      
      // Also catch keypress and block 'e', '+', '-', '.' since we only want positive integers
      inputEl.addEventListener('keydown', (e) => {
        if (['e', 'E', '+', '-', '.'].includes(e.key)) {
          e.preventDefault();
        }
      });
    });

    // Initial calculation to set base states
    calculateTuition();
  </script>
</body>
